# Copy to .env for local dev. In production set these in the Render dashboard.

# --- Auth (required) ---
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
# Used to sign the session cookie. Use a long random string (32+ chars).
SESSION_SECRET=replace-with-a-long-random-secret

# --- Gemini (optional) ---
# Without a key, the office runs in simulation mode (no real LLM calls).
GEMINI_API_KEY=
# Your assigned tasks run on this model. gemini-2.5-pro (best, needs billing)
# or gemini-2.5-flash (cheaper/free tier).
GEMINI_MODEL=gemini-2.5-pro
# AUTO demo model — free-tier Flash by default; set to empty for pure simulation.
GEMINI_DEMO_MODEL=gemini-2.5-flash

# --- Database (optional locally) ---
# Without DATABASE_URL the server keeps state in memory (resets on restart).
# DATABASE_URL=postgres://user:pass@localhost:5432/missioncontrol

# --- Tuning (optional) ---
# PORT=3000
# TICK_MS=1500
# AUTONOMOUS=true
